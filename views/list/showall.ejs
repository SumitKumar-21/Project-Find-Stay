<% if (list.length===0 && (search || categoryName) ) { %>
  <div class="d-flex justify-content-center align-items-center text-center" style="min-height: 60vh;" > <h1 >Sorry No Result found</h1></div>
<% } else if (categoryName || search) { %>
  <h1>Popular Choices</h1>
<% } else { %>
  <h1>Trending</h1>
<% } %>

      
          
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
  <% list.forEach(function (l) { %>
    <div class="col">
      <a href="/showall/<%= l.id %>" class="showOne text-decoration-none text-dark">
        <div class="listing-card">
          <div class="listing-img-box">
            <img
              src="<%= l.Image.url %>"
              class="listing-img"
              alt="<%= l.title %>"
            >
          </div>
          <div class="listing-body">
            <h5 class="listing-title"><%= l.title %></h5>
            <p class="listing-location"><%= l.location %>, <%= l.country %></p>
            <p class="listing-price">
              &#x20B9; <%= l.price.toLocaleString("en-IN") %>
              <span>per night</span>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% }); %>
</div>
  

 
